{
  "mcpServers": {
    "aso": {
      "command": "npx",
      "args": ["tsx", "${CLAUDE_PLUGIN_ROOT}/src/server.ts"],
      "env": {
        "ASO_CONFIG_PATH": "${CLAUDE_PLUGIN_DATA}/config.json",
        "ASO_DATA_PATH": "${CLAUDE_PLUGIN_DATA}/data"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "mkdir -p \"${CLAUDE_PLUGIN_DATA}/data\""
      },
      {
        "type": "prompt",
        "prompt": "Check if the file at the path in the ASO_CONFIG_PATH environment variable exists. If it does not exist, tell the user to run /aso-config to set up the ASO plugin."
      }
    ]
  }
}
